local LibraryName = "Notification Library"
local NotificationLibrary = {}

local TweenService = game:GetService("TweenService")
local CoreGui = cloneref(game:GetService("CoreGui"))

local library
local canvas

local THEMES = {
    Success = {
        primary = Color3.fromRGB(34, 197, 94),
        secondary = Color3.fromRGB(22, 163, 74),
        glow = Color3.fromRGB(134, 239, 172),
        icon = "✓"
    },
    Error = {
        primary = Color3.fromRGB(239, 68, 68),
        secondary = Color3.fromRGB(220, 38, 38),
        glow = Color3.fromRGB(252, 165, 165),
        icon = "✕"
    },
    Warning = {
        primary = Color3.fromRGB(245, 158, 11),
        secondary = Color3.fromRGB(217, 119, 6),
        glow = Color3.fromRGB(253, 230, 138),
        icon = "⚠"
    },
    Info = {
        primary = Color3.fromRGB(59, 130, 246),
        secondary = Color3.fromRGB(37, 99, 235),
        glow = Color3.fromRGB(147, 197, 253),
        icon = "ℹ"
    }
}

function NotificationLibrary:Load()
    local screen = Instance.new("ScreenGui")
    screen.Name = LibraryName
    screen.ResetOnSpawn = false
    screen.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    screen.Parent = CoreGui
    
    local holder = Instance.new("Frame")
    holder.Name = "list"
    holder.AnchorPoint = Vector2.new(1, 0)
    holder.Position = UDim2.new(1, -25, 0, 25)
    holder.Size = UDim2.new(0, 380, 1, -50)
    holder.BackgroundTransparency = 1
    holder.Parent = screen
    
    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 15)
    layout.Parent = holder
    
    library = screen
    canvas = holder
end

local function getLibrary()
    local existing = CoreGui:FindFirstChild(LibraryName)
    if not existing then
        NotificationLibrary:Load()
    else
        library = existing
        canvas = library.list
    end
end

local function createCard(theme, text)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0, 0, 0, 0)
    card.BackgroundColor3 = Color3.fromRGB(20, 25, 35)
    card.BorderSizePixel = 0
    card.ClipsDescendants = true
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 14)
    corner.Parent = card
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = theme.primary
    stroke.Thickness = 2.5
    stroke.Transparency = 0.4
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = card
    
    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, 5, 1, 0)
    accentBar.BackgroundColor3 = theme.primary
    accentBar.BorderSizePixel = 0
    accentBar.Parent = card
    
    local barCorner = Instance.new("UICorner")
    barCorner.CornerRadius = UDim.new(1, 0)
    barCorner.Parent = accentBar
    
    local iconBg = Instance.new("Frame")
    iconBg.Size = UDim2.new(0, 52, 0, 52)
    iconBg.Position = UDim2.new(0, 18, 0.5, 0)
    iconBg.AnchorPoint = Vector2.new(0, 0.5)
    iconBg.BackgroundColor3 = theme.primary
    iconBg.BorderSizePixel = 0
    iconBg.Parent = card
    
    local iconCorner = Instance.new("UICorner")
    iconCorner.CornerRadius = UDim.new(1, 0)
    iconCorner.Parent = iconBg
    
    local iconText = Instance.new("TextLabel")
    iconText.Size = UDim2.new(1, 0, 1, 0)
    iconText.BackgroundTransparency = 1
    iconText.Text = theme.icon
    iconText.TextColor3 = Color3.fromRGB(255, 255, 255)
    iconText.TextSize = 28
    iconText.Font = Enum.Font.GothamBold
    iconText.Parent = iconBg
    
    local glow = Instance.new("ImageLabel")
    glow.Size = UDim2.new(0, 52, 0, 52)
    glow.Position = UDim2.new(0, 18, 0.5, 0)
    glow.AnchorPoint = Vector2.new(0, 0.5)
    glow.BackgroundTransparency = 1
    glow.Image = "rbxassetid://4996891970"
    glow.ImageColor3 = theme.glow
    glow.ImageTransparency = 0.5
    glow.ZIndex = 0
    glow.Parent = card
    
    local message = Instance.new("TextLabel")
    message.Size = UDim2.new(1, -95, 1, -30)
    message.Position = UDim2.new(0, 82, 0, 15)
    message.BackgroundTransparency = 1
    message.Text = text
    message.TextColor3 = Color3.fromRGB(245, 245, 245)
    message.TextSize = 16
    message.Font = Enum.Font.GothamMedium
    message.TextWrapped = true
    message.TextXAlignment = Enum.TextXAlignment.Left
    message.TextYAlignment = Enum.TextYAlignment.Top
    message.Parent = card
    
    local progressBg = Instance.new("Frame")
    progressBg.Size = UDim2.new(1, -36, 0, 4)
    progressBg.Position = UDim2.new(0, 18, 1, -12)
    progressBg.AnchorPoint = Vector2.new(0, 1)
    progressBg.BackgroundColor3 = Color3.fromRGB(40, 45, 55)
    progressBg.BorderSizePixel = 0
    progressBg.Parent = card
    
    local progressCorner = Instance.new("UICorner")
    progressCorner.CornerRadius = UDim.new(1, 0)
    progressCorner.Parent = progressBg
    
    local progress = Instance.new("Frame")
    progress.Size = UDim2.new(1, 0, 1, 0)
    progress.BackgroundColor3 = theme.primary
    progress.BorderSizePixel = 0
    progress.Parent = progressBg
    
    local progressInnerCorner = Instance.new("UICorner")
    progressInnerCorner.CornerRadius = UDim.new(1, 0)
    progressInnerCorner.Parent = progress
    
    return card, progress, glow, iconBg, stroke
end

function NotificationLibrary:SendNotification(Mode, Text, Duration)
    getLibrary()
    
    local theme = THEMES[Mode]
    if not theme then
        warn("Invalid theme applied")
        return
    end
    
    Duration = Duration or 4
    
    task.spawn(function()
        local card, progress, glow, iconBg, stroke = createCard(theme, Text)
        card.Parent = canvas
        card.Position = UDim2.new(1.2, 0, 0, 0)
        
        local slideIn = TweenService:Create(card, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0),
            Size = UDim2.new(1, 0, 0, 95)
        })
        slideIn:Play()
        
        task.wait(0.2)
        
        local glowPulse = TweenService:Create(glow, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
            ImageTransparency = 0.2,
            Size = UDim2.new(0, 65, 0, 65)
        })
        glowPulse:Play()
        
        local iconSpin = TweenService:Create(iconBg, TweenInfo.new(0.7, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {
            Rotation = 360
        })
        iconSpin:Play()
        
        local strokeFade = TweenService:Create(stroke, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
            Transparency = 0.7
        })
        strokeFade:Play()
        
        local progressTween = TweenService:Create(progress, TweenInfo.new(Duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 1, 0)
        })
        progressTween:Play()
        
        task.wait(Duration)
        
        glowPulse:Cancel()
        strokeFade:Cancel()
        
        local slideOut = TweenService:Create(card, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Position = UDim2.new(1.2, 0, 0, 0),
            Size = UDim2.new(0, 0, 0, 0)
        })
        slideOut:Play()
        
        task.wait(0.5)
        card:Destroy()
    end)
end

return NotificationLibrary
